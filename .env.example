# Supabase — copie este arquivo para `.env` e preencha com os valores do seu projeto.
# Encontre estes valores em: Supabase Dashboard > Project Settings > API
# IMPORTANTE: no Vite, variáveis expostas ao client DEVEM começar com `VITE_`.

VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sua-anon-public-key-aqui
